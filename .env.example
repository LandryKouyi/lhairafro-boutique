# ============================================================================
#  L'Hair Afro — Boutique en ligne · variables d'environnement (modèle)
#  Copier ce fichier en « .env » et compléter. Ne JAMAIS committer le vrai .env.
#  Le mot de passe API PVit est SECRET : Landry le pose lui-même (dashboard Render
#  ou .env local), jamais écrit ici.
# ============================================================================

# --- Serveur ----------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Chemin de la base SQLite. En prod Render (disque persistant) : /var/data/lhairafro.db
DATABASE_PATH=./data/lhairafro.db
# URL publique du site (auto-remplie par Render via RENDER_EXTERNAL_URL).
PUBLIC_URL=
# Origines autorisées (CORS), séparées par des virgules.
CORS_ORIGINS=http://localhost:3000

# --- Identité boutique ------------------------------------------------------
BOUTIQUE_NOM=L'Hair Afro
BOUTIQUE_SLOGAN=The Afro beauty concept store
BOUTIQUE_VILLE=Libreville, Gabon
BOUTIQUE_TELEPHONE=+241 74 59 87 50
# Numéro WhatsApp de la boutique (international, sans +). 074598750 -> 24174598750.
# À la remise : mettre le numéro définitif de Ludmilla.
BOUTIQUE_WHATSAPP=24174598750

# ============================================================================
#  PVit / MyPVit — paiement Mobile Money (Airtel + Moov). Compte L'Hair Afro.
#  Tant que PVIT_API_PASSWORD est vide, le paiement Mobile Money est DÉSACTIVÉ
#  proprement (mode « à la livraison » + repli WhatsApp toujours dispo).
# ============================================================================
PVIT_SLUG=MR_1784284130
PVIT_BASE_URL=https://api.mypvit.pro

# Compte d'opération (TEST : ACC_6A5A03E304ADF ; PROD : créé après validation).
PVIT_OPERATION_ACCOUNT=ACC_6A5A03E304ADF

# SECRET — mot de passe API défini via la page APIs de PVit (RENEW SECRET KEY,
# OTP par email). À poser par Landry lui-même. Laisser vide ici.
PVIT_API_PASSWORD=

# Chemins d'endpoint (page Paramétrages → APIs de PVit L'Hair Afro).
PVIT_URL_RENEW=/FMVCNVSMXCXS5RGQ/renew-secret
PVIT_URL_REST=/v2/KPZTKPA5GQT1ZFNS/rest
# CHECK STATUS : code d'endpoint à relever sur la page APIs (non encore noté).
# Vide = check status désactivé (confirmation par webhook uniquement).
PVIT_URL_STATUS=

# Codes d'URL à CRÉER dans PVit (Paramétrages → Urls) une fois le domaine lié :
#   - callback (type CALLBACK)      -> https://<domaine>/api/pvit-callback
#   - réception de clé (type ...)   -> https://<domaine>/api/pvit-secret
# Renseigner ici les codes générés par PVit pour chacune.
PVIT_CALLBACK_URL_CODE=
PVIT_RECEPTION_URL_CODE=

# Métadonnées facultatives.
PVIT_AGENT=LHAIR-AFRO
PVIT_PRODUCT=BOUTIQUE
PVIT_OWNER_CHARGE=CUSTOMER
PVIT_OWNER_CHARGE_OPERATOR=CUSTOMER
