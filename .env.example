# ============================================================================
#  L'Hair Afro — Boutique en ligne · variables d'environnement (modèle)
#  Copier ce fichier en « .env » et compléter. Ne JAMAIS committer le vrai .env.
#  Le mot de passe API PVit est SECRET : Landry le pose lui-même (dashboard Render
#  ou .env local), jamais écrit ici.
# ============================================================================

# --- Serveur ----------------------------------------------------------------
NODE_ENV=development
PORT=3000
# Chemin de la base SQLite. En prod Render (disque persistant) : /var/data/lhairafro.db
DATABASE_PATH=./data/lhairafro.db
# Dossier des photos produits téléversées. Par défaut : à côté de la base.
# En prod Render (disque persistant) : /var/data/uploads
UPLOADS_DIR=

# --- Arrière-boutique (espace de gestion de Ludmilla) -----------------------
# Mot de passe MAÎTRE de l'espace /admin. SECRET — à poser par Landry (Render /
# .env local). Il sert à 2 choses : (1) mot de passe de PREMIÈRE connexion donné
# à Ludmilla ; (2) clé de « bris de glace » ultime si elle perd son mot de passe
# ET son code de récupération. C'est aussi la racine de signature des sessions,
# donc il doit rester posé. Ludmilla définit ensuite SON propre mot de passe
# (que Landry ne connaît pas) depuis l'onglet Réglages ; le maître reste un
# recours d'urgence. Tant qu'il est vide, l'accès admin est VERROUILLÉ.
ADMIN_PASSWORD=
# (Optionnel) sel de signature des sessions ; changer le mot de passe suffit à
# invalider les sessions ouvertes.
ADMIN_SESSION_SECRET=
# (Optionnel) durée d'une session admin en heures (défaut 12).
ADMIN_SESSION_HEURES=12
# URL publique du site (auto-remplie par Render via RENDER_EXTERNAL_URL).
PUBLIC_URL=
# Origines autorisées (CORS), séparées par des virgules.
CORS_ORIGINS=http://localhost:3000

# --- Identité boutique ------------------------------------------------------
BOUTIQUE_NOM=L'Hair Afro
BOUTIQUE_SLOGAN=The Afro beauty concept store
BOUTIQUE_VILLE=Libreville, Gabon
BOUTIQUE_TELEPHONE=+241 74 59 87 50
# Numéro WhatsApp de la boutique (international, sans +). 074598750 -> 24174598750.
# À la remise : mettre le numéro définitif de Ludmilla.
BOUTIQUE_WHATSAPP=24174598750

# ============================================================================
#  PVit / MyPVit — paiement Mobile Money (Airtel + Moov). Compte L'Hair Afro.
#  Tant que PVIT_API_PASSWORD est vide, le paiement Mobile Money est DÉSACTIVÉ
#  proprement (mode « à la livraison » + repli WhatsApp toujours dispo).
# ============================================================================
PVIT_SLUG=MR_1784284130
PVIT_BASE_URL=https://api.mypvit.pro

# Compte d'opération (TEST : ACC_6A5A03E304ADF ; PROD : créé après validation).
PVIT_OPERATION_ACCOUNT=ACC_6A5A03E304ADF

# SECRET — mot de passe API défini via la page APIs de PVit (RENEW SECRET KEY,
# OTP par email). À poser par Landry lui-même. Laisser vide ici.
PVIT_API_PASSWORD=

# Chemins d'endpoint (page Paramétrages → APIs de PVit L'Hair Afro).
PVIT_URL_RENEW=/FMVCNVSMXCXS5RGQ/renew-secret
PVIT_URL_REST=/v2/KPZTKPA5GQT1ZFNS/rest
# CHECK STATUS (v1) et KYC (v2) : codes relevés sur la page APIs (déjà en dur
# dans config.js ; surchargeables ici si les codes changent en production).
PVIT_URL_STATUS=/FYS1XHAGYCF4X1YX/status
PVIT_URL_KYC=/v2/4ZGW50N5YLCFKTEY/kyc

# Codes d'URL créés dans PVit (Paramétrages → Urls), mode TEST L'Hair Afro :
#   - callback (type CALLBACK)         -> https://lhairafro.com/api/pvit-callback  -> code MKTAO
#   - réception de clé (type dédié)    -> https://lhairafro.com/api/pvit-secret    -> code 7UMSP
# En production, si les URLs sont recréées, remplacer par les nouveaux codes.
PVIT_CALLBACK_URL_CODE=MKTAO
PVIT_RECEPTION_URL_CODE=7UMSP

# Métadonnées facultatives.
PVIT_AGENT=LHAIR-AFRO
PVIT_PRODUCT=BOUTIQUE
PVIT_OWNER_CHARGE=CUSTOMER
PVIT_OWNER_CHARGE_OPERATOR=CUSTOMER

# ============================================================================
#  Messagerie de l'arrière-boutique (boîte contact@lhairafro.com)
#  Envoi via SMTP Gmail (compte relais dédié) ; réception via Cloudflare Worker.
#  Tant que GMAIL_USER / GMAIL_APP_PASSWORD sont vides, l'envoi est désactivé
#  proprement (le module Messagerie s'affiche « en attente d'activation »).
# ============================================================================
# SECRET — compte Gmail relais de la boutique (ex. contact.lhairafro@gmail.com).
GMAIL_USER=
# SECRET — mot de passe d'application (16 caractères, Google → Sécurité →
# Mots de passe des applications ; 2FA requise). Les espaces sont ignorés.
GMAIL_APP_PASSWORD=
# Adresse expéditrice affichée = l'alias « Envoyer en tant que » validé dans
# le compte Gmail relais. Ne touche pas aux MX/OTP.
MAIL_FROM_EMAIL=contact@lhairafro.com
MAIL_FROM_NAME=L'Hair Afro
# SECRET — jeton partagé protégeant le webhook /api/mail-inbound. Générer une
# valeur aléatoire (ex. `openssl rand -hex 24`) et la mettre AUSSI dans le
# Cloudflare Email Worker. Vide = réception désactivée.
MAIL_INBOUND_TOKEN=
